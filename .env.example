# Facebook Pages MCP Server — Environment Variables
#
# Generate your token at: https://developers.facebook.com/tools/explorer/
#
# Required permissions: pages_show_list, pages_read_engagement
# Recommended: business_management (if Pages are managed via Business Manager)
#
# For Business Manager pages, get tokens via:
#   GET /me/businesses?fields=id,name
#   GET /{business-id}/owned_pages?fields=id,name,access_token
#
# For personal pages:
#   GET /me/accounts?fields=id,name,access_token

# Long-lived Page Access Token
FB_PAGE_ACCESS_TOKEN=your_page_access_token_here

# Default Facebook Page ID (numeric)
FB_PAGE_ID=your_page_id_here
